{
  "name": "@hd-search/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "HD-Search — search + crawl + vector-search aggregator API. Priority-ordered provider fallback, Redis/RediSearch cache, encrypted per-user keys. Hono + TypeScript.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "postbuild": "mkdir -p dist/src/ai && cp src/ai/llm-providers.json dist/src/ai/",
    "start": "node dist/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "keys": "tsx scripts/hds-keys.ts",
    "migrate": "tsx scripts/migrate.ts",
    "mcp": "tsx mcp/server.ts",
    "test:api": "tsx scripts/api-test.ts",
    "test:mcp": "tsx scripts/mcp-test.ts"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.121",
    "@ai-sdk/anthropic": "^3.0.86",
    "@ai-sdk/azure": "^3.0.77",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.74",
    "@anthropic-ai/sdk": "^0.105.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ai": "^6.0.209",
    "fflate": "^0.8.3",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "socks-proxy-agent": "^8.0.4",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "ag-psd": "^24.0.0",
    "pdfjs-dist": "^4.10.38",
    "tesseract.js": "^5.1.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
