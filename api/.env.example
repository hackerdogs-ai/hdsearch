# ─────────────────────────────────────────────────────────────────────────────
# HD-Search API configuration. Copy to .env (local) and fill in.
# Real process env always wins over this file.
# HD-Search is an INDEPENDENT service: this file is self-contained and shares no
# files with hackerdogs-core/worldmonitor. Values may DUPLICATE core values (same
# JWT secret, same Auth0 tenant) but are set explicitly here, never linked.
# ─────────────────────────────────────────────────────────────────────────────

# ---- server ----
HDSEARCH_API_PORT=8791
HDSEARCH_API_HOST=0.0.0.0
HDSEARCH_LOG_LEVEL=info
# dev  → commercial .env keys below are used as a fallback for ALL users
# prod → only per-user encrypted keys from Postgres are used
RUN_MODE=dev

# ---- existing infra (already running in docker on the hdnet network) ----
# Shared hd-redis (Redis Stack). hd-search keyspace on db 5 — isolated from db 0 (core),
# db 1 (hd-feeds), db 3/4 (celery), db 15 (worldmonitor). Requires ./start_core_infra.sh up.
HDSEARCH_REDIS_URL=redis://127.0.0.1:6379/5
# Vectors use RediSearch, which ONLY indexes db 0 — so the vector index + `hds:vec:` docs
# live on db 0 (prefix-isolated). Defaults to the redisUrl host but db 0; override here.
HDSEARCH_VECTOR_REDIS_URL=redis://127.0.0.1:6379/0
# Postgres / TimescaleDB (hd-db). Database: hdsearch. See db/CREDENTIALS.md.
# App runtime uses the LEAST-PRIVILEGE read/write role (no DDL):
HDSEARCH_DATABASE_URL=postgres://hdsearchrw:HdSearch-RW-2026.Dev@127.0.0.1:5432/hdsearch
# Migrations (DDL) run as the schema-owner role:
HDSEARCH_MIGRATION_DATABASE_URL=postgres://hdsearchadmin:HdSearch-Admin-2026.Dev@127.0.0.1:5432/hdsearch
HDSEARCH_PG_SCHEMA=hd_search
# SeaweedFS S3 (hd-seaweedfs)
HDSEARCH_S3_ENDPOINT=http://127.0.0.1:8333
STORAGE_AWS_REGION=us-east-1
STORAGE_AWS_ACCESS_KEY_ID=admin
STORAGE_AWS_SECRET_ACCESS_KEY=key
HDSEARCH_BUCKET=hd-search

# ---- central auth (hackerdogs-core SSO) — see docs/AUTH_PLAN_INTEGRATION.md ----
# legacy = own session + sk-hds keys only (default). core = also accept the central
# Hackerdogs JWT. both = run both during cutover. Flip per-env; 'legacy' is the rollback.
HDSEARCH_AUTH_MODE=both
# Shared HS256 secret the core signs JWTs with (must equal hackerdogs-core JWT_SECRET_KEY).
JWT_SECRET_KEY=
# Core API base for resolving a user's plan by JWT (GET /auth/me) — same as worldmonitor's auth base.
HD_CORE_BASE_URL=http://localhost:8000
# Optional JWT for public plan catalog (GET /v1/plans → core /gpdtplansui). When unset,
# pricing falls back to seed values from scripts/upload_plans.py until a user session
# or service token can reach core.
# HD_CORE_CATALOG_JWT=
# Email verification allowlist lives on the core API host (root .env), not here:
# VERIFICATION_API_BASE, VERIFICATION_ALLOWED_ORIGINS, VERIFICATION_REDIRECT

# ---- encryption for per-user provider keys (AES-256-GCM) ----
# Leave blank to AUTO-GENERATE + persist to .hdsearch-secrets.json (works out of the
# box). Set explicitly in production (openssl rand -hex 32) and BACK UP the file —
# losing this key makes stored provider keys unrecoverable.
HDSEARCH_ENCRYPTION_KEY=

# ---- internal trust for the Next.js panel (BFF → API) ----
# Shared secret; the web app passes X-HD-Internal + X-HD-User. For a self-contained
# service set this EXPLICITLY here AND to the same value in web/.env.local (rather than
# relying on the auto-generated shared file). Generate: openssl rand -hex 32
HDSEARCH_INTERNAL_SECRET=
# Optional: pin the auto-generated secrets file INSIDE hd-search so it never lands in a
# shared parent dir (only used if the secrets above are left blank).
# HDSEARCH_SECRETS_FILE=./.hdsearch-secrets.json

# ---- self-hosted providers (highest priority, free) ----
HDSEARCH_OPENSERP_URL=http://127.0.0.1:7007
HDSEARCH_SEARXNG_URL=http://127.0.0.1:8899
HDSEARCH_CRAWL4AI_URL=http://127.0.0.1:11235   # reuses hackerdogs-crawl4ai
HDSEARCH_BROWSERLESS_URL=http://127.0.0.1:3000   # reuses hackerdogs-browserless
HDSEARCH_AHMIA_URL=https://ahmia.fi

# ---- maps / geocoding (the `maps` modality) ----
# Engine: 'photon' (komoot, self-hostable) or 'nominatim' (OSM, self-hostable).
# Defaults to the public Photon instance; point HDSEARCH_GEOCODER_URL at your own
# container for zero-cost self-hosting (both use OpenStreetMap data).
HDSEARCH_GEOCODER_ENGINE=photon
# HDSEARCH_GEOCODER_URL=http://127.0.0.1:2322        # self-hosted Photon
# HDSEARCH_GEOCODER_URL=http://127.0.0.1:8088        # self-hosted Nominatim
# Overpass API — powers "<category> in <place>" maps queries (e.g. "pharmacies in
# Dublin, CA" → all pharmacy POIs). Free public default; self-hostable.
HDSEARCH_OVERPASS_URL=https://overpass-api.de/api/interpreter
# AI Search "plot on a map" (hd_plot_map) geocodes named regions. Photon is tried first;
# weak matches fall back to Nominatim (authoritative for countries/regions). Public default;
# point at your own Nominatim for zero rate limits:
# HDSEARCH_NOMINATIM_URL=http://127.0.0.1:8088

# ---- AI Mode / AI Search (the `ai` modality — conversational, tool-augmented answers) ----
# Multi-provider: pick a model from the picker or let the OR optimizer auto-select.
#
# Anthropic (Claude) — server-wide key here, OR per-user under Account → Provider Keys
# (field "anthropic"), OR HDSEARCH_DEV_KEY_anthropic in dev. Adding a key makes the
# Claude models "available" in the picker; no key → they show "needs key".
# HDSEARCH_ANTHROPIC_KEY=sk-ant-...
#
# Ollama (local / self-hosted LLMs) — no key, $0 provider cost. Whatever you've pulled
# (`ollama pull qwen3-coder`) is auto-discovered and appears in the picker as "· free".
# Tool calling requires a tools-capable model (qwen3-coder, llama3.1, etc.).
HDSEARCH_OLLAMA_URL=http://127.0.0.1:11434
#
# MCP servers — external tool providers the agent can call alongside the built-ins.
# JSON array; three transports (stdio | http | sse). Tools are namespaced mcp__<id>__<tool>.
#   stdio: {"id":"demo","transport":"stdio","command":"node","args":["mcp/examples/demo-server.mjs"]}
#   http:  {"id":"github","transport":"http","url":"https://…/mcp","headers":{"Authorization":"Bearer …"}}
# HDSEARCH_MCP_SERVERS=[{"id":"demo","transport":"stdio","command":"node","args":["mcp/examples/demo-server.mjs"]}]
#
# Credit metering (self-contained; mirrors hackerdogs credit model). 1 credit = $0.01.
# Self-hosted (Ollama) runs cost 0 credits; commercial models are metered by token price.
HDSEARCH_USD_TO_CREDIT_RATE=100
HDSEARCH_AI_MARGIN=0.80          # 80% margin: price = providerCost / (1 - margin)
# Web map style (MapLibre). Defaults to OpenStreetMap raster tiles (no key);
# set to a self-hosted style.json for fully self-hosted tiles.
# NEXT_PUBLIC_MAP_STYLE=https://tiles.example.com/style.json

# ---- vector / embeddings (pluggable; default self-hosted MiniLM) ----
HDSEARCH_EMBEDDINGS_PROVIDER=minilm
HDSEARCH_EMBEDDINGS_URL=http://127.0.0.1:8081   # transformers-inference (hd-weaviate-t2v) host 8081
HDSEARCH_VECTOR_DIM=384                          # minilm=384, openai-3-small=1536
HDSEARCH_VECTOR_TTL=86400                        # 24h default
# OPENAI_API_KEY=                                # only if EMBEDDINGS_PROVIDER=openai

# ---- file upload + processing + RAG (see docs/file-upload-rag.md) ----
# Core processors (text/json/xml/generic + docx/pptx/odt via bundled fflate) work out
# of the box. For pdf/xlsx/psd/OCR install the optional parsers:
#   npm i pdfjs-dist ag-psd tesseract.js 'xlsx@https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz'
# HDSEARCH_FILE_MAX_BYTES=209715200               # 200 MB upload cap
# HDSEARCH_FILE_VECTOR_TTL=2592000                # 30d TTL for file chunks in the vector store
# HDSEARCH_FILE_WORKER_CONCURRENCY=2              # in-process processing workers
# HDSEARCH_FILE_MAX_ATTEMPTS=3                    # retry cap before dead-letter
# HDSEARCH_FILE_JOB_STALE_MS=120000              # heartbeat staleness → reap/retry
# HDSEARCH_FILE_PROCESS_TIMEOUT_MS=300000        # per-file processing budget
# HDSEARCH_FILE_MAX_PAGES=2000                    # page cap (pdf/office)
# HDSEARCH_FILE_MAX_CHARS=5000000                 # extracted-char cap
# HDSEARCH_FILE_OCR=off                           # OCR images/scanned pages (needs tesseract.js)
# HDSEARCH_FILE_VISION=off                        # vision captioning via existing LLM vision keys
# HDSEARCH_FILE_AV_URL=                           # optional antivirus scan endpoint (empty = disabled)
# HDSEARCH_FILE_AV_FAIL_CLOSED=0                  # 1 = quarantine on scanner outage
# HDSEARCH_FILE_RAG_TOPK=8                        # chunks injected into a grounded chat turn
# HDSEARCH_FILE_RAG_MIN_SCORE=0.2                 # minimum cosine similarity to include a chunk
# HDSEARCH_FIGMA_TOKEN=                           # Figma REST access for the figma processor

# ---- audio/video transcription (Whisper) — makes AV uploads searchable via RAG ----
# provider: local (self-hosted OpenAI-compatible /v1/audio/transcriptions, e.g.
# faster-whisper-server) | openai | none (default, off). No extra npm deps.
# HDSEARCH_TRANSCRIBE_PROVIDER=none
# HDSEARCH_TRANSCRIBE_URL=http://127.0.0.1:8082/v1/audio/transcriptions
# HDSEARCH_TRANSCRIBE_MODEL=whisper-1
# HDSEARCH_TRANSCRIBE_MAX_BYTES=26214400          # 25 MB cap (OpenAI limit)
# HDSEARCH_TRANSCRIBE_KEY=                         # falls back to OPENAI_API_KEY
# HDSEARCH_TRANSCRIBE_TIMEOUT_MS=120000

# ---- commercial provider DEV keys (used ONLY when RUN_MODE=dev) ----
SERPAPI_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
KAGI_API_KEY=
FIRECRAWL_API_KEY=
JINA_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
INTELX_API_KEY=

# ---- hdfeeds integration (search trends panel) ----
# Terminal: http://localhost:8787 (default below). Docker: fixed at http://hdfeeds:8787 in compose.
#
# Sync the internal secret once (same value both sides):
#   python tools/gen-apikey-secret.py --apply
# Or manually: hdfeeds n8n/hd-feeds.env HDFEEDS_INTERNAL_SECRET → api/.env HDSEARCH_HDFEEDS_INTERNAL_SECRET
#
# Optional fallback instead of internal secret: a feeds:read sk-hdf- key from hdfeeds.
HDSEARCH_HDFEEDS_BASE_URL=http://localhost:8787
HDSEARCH_HDFEEDS_INTERNAL_SECRET=
# HDSEARCH_HDFEEDS_API_KEY=
# HDSEARCH_HDFEEDS_TIMEOUT_MS=5000
# HDSEARCH_TRENDS_WINDOW_HOURS=24
# HDSEARCH_TRENDS_LIMIT=12
# HDSEARCH_TRENDS_CACHE_TTL=600
# HDSEARCH_TRENDS_MIN_USERS=3

# Open-source build: no billing. Plans/credits/quotas are disabled and Stripe is
# not used (billing was a SaaS concern owned by an external service).
HDSEARCH_APP_URL=http://localhost:3000

# ---- bootstrap (optional): install a known admin API key on first boot ----
# HDSEARCH_API_BOOTSTRAP_ADMIN_KEY=sk-hds-replace-me

# ---- Tor proxy for .onion darkweb providers (ahmia onion fallback, torch) ----
# host: socks5h://127.0.0.1:9050   |  in compose: socks5h://hackerdogs-tor-proxy:9050
HDSEARCH_TOR_PROXY=socks5h://127.0.0.1:9050

# ─────────────────────────────────────────────────────────────────────────────
# ADVANCED / TUNING (all optional — defaults shown). Uncomment to override.
# ─────────────────────────────────────────────────────────────────────────────

# ---- server / logging ----
# HDSEARCH_API_HOST=0.0.0.0
# HDSEARCH_LOG_LEVEL=info                 # debug|info|warn|error
# HDSEARCH_CORS_ORIGINS=                  # comma list; empty = allow all (*)

# ---- redis namespacing / s3 prefix ----
# HDSEARCH_REDIS_PREFIX=hds               # key prefix on the redis db
# HDSEARCH_PREFIX=hd-search               # S3 object key prefix

# ---- engine behaviour ----
# HDSEARCH_DEFAULT_CACHE_TTL=900          # admin/env default result-cache TTL (sec); used when request omits ttl
# HDSEARCH_MAX_CACHE_TTL=86400            # admin/env hard max result-cache TTL (sec); over-max → default
# HDSEARCH_PROVIDER_TIMEOUT_MS=10000      # per upstream provider call timeout
# HDSEARCH_PROVIDER_RETRIES=1             # retries per provider call (honors Retry-After)
# HDSEARCH_MAX_RESULTS=50                 # hard cap on results
# HDSEARCH_AGGREGATE_FANOUT=5             # engines queried in aggregate mode
# HDSEARCH_AGGREGATE_DEADLINE_MS=6000     # aggregate soft deadline (tail-latency cap)
# HDSEARCH_API_DEFAULT_RATE_LIMIT=120     # per-key/per-user requests/min
# HDSEARCH_API_KEY_CACHE_MS=10000         # API-key verify cache window

# ---- priority list ----
# HDSEARCH_PRIORITY_CSV=src/priorities.csv
# HDSEARCH_PRIORITY_RELOAD_SEC=300        # hot-reload interval for the CSV

# ---- vector index ----
# HDSEARCH_VECTOR_INDEX=hds:vec:idx       # RediSearch index name
# HDSEARCH_OPENAI_EMBED_MODEL=text-embedding-3-small  # when EMBEDDINGS_PROVIDER=openai

# ---- OpenSERP (self-hosted SERP scraper) ----
# HDSEARCH_OPENSERP_ENGINES=google,yandex,bing,baidu  # fanned out + merged
# HDSEARCH_OPENSERP_ENGINE=yandex         # single-engine fallback if _ENGINES unset
# HDSEARCH_OPENSERP_MERGE=true            # merge all engines (false = first-with-results)
# HDSEARCH_OPENSERP_TIMEOUT_MS=30000      # per-engine timeout (browser scrapes are slow)

# ---- darkweb / Tor ----
# HDSEARCH_AHMIA_ONION=http://juhanurmihxlp77nkq76byazcldy2hlmovfu2epvl5ankdibsot4csyd.onion
# HDSEARCH_TORCH_ONION=http://torchdeedp3i2jigzjdmfpn5ttjhthh5wbmda2rr3jvqjg5p77c54dqd.onion

# ---- crawl / content extraction endpoints ----
# HDSEARCH_BROWSERLESS_TOKEN=             # token for hackerdogs-browserless (if set)
# HDSEARCH_FIRECRAWL_URL=https://api.firecrawl.dev   # or your self-hosted firecrawl
# HDSEARCH_CC_INDEX=CC-MAIN-2025-08       # Common Crawl index collection
# HDSEARCH_INTELX_URL=https://2.intelx.io # Intelligence X API base

# ---- anonymous demo users (exempt from monthly quota; bounded by rate limit) ----
# HDSEARCH_DEMO_USERS=public-demo
# HDSEARCH_DEMO_RATE_LIMIT=6000          # shared per-min rate limit for the anonymous demo bucket

# ---- secret provisioning (auto-generated to a shared file if env unset) ----
# HDSEARCH_SECRETS_FILE=../.hdsearch-secrets.json   # relocate the shared secrets file (mount a volume in Docker)

# ---- Email (optional) --------------------------------------------------------
# Enables password reset and magic-link sign-in. Leave unset to run without email;
# those flows are then hidden in the UI. An admin can also set these in
# System Admin -> Email, where the password is stored encrypted (that wins over env).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# true = implicit TLS on connect (port 465); false = STARTTLS (587)
SMTP_SECURE=false
# Public URL of the web app — used to build links in emails.
HDSEARCH_APP_BASE_URL=http://localhost:3000
