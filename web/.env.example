# ───────────────────────────────────────────────────────────────────────────
# HD-Search web (Next.js) configuration. Copy to .env (dev) or .env.prod (prod).
# HD-Search is an INDEPENDENT service: this file is self-contained and shares no
# files with hackerdogs-core/worldmonitor. Values may DUPLICATE core values
# (same Auth0 tenant, etc.) but are set explicitly here, never linked.
# ───────────────────────────────────────────────────────────────────────────

# hdsearch API (BFF target). Local: 127.0.0.1; in docker: http://hdsearch:8791
HDSEARCH_API_URL=http://127.0.0.1:8791
# Shown in client docs/integrations pages (browser-visible). Use the public URL in prod.
NEXT_PUBLIC_API_URL=http://localhost:8791

# Shared secret the API trusts for first-party calls — MUST equal the API's
# HDSEARCH_INTERNAL_SECRET (set the same value in BOTH files). Generate: openssl rand -hex 32
HDSEARCH_INTERNAL_SECRET=

# Cookie signing secret for the web session. Generate: openssl rand -hex 32
HDSEARCH_WEB_SESSION_SECRET=

# Public base URL of THIS web app (used for OAuth redirect URLs)
APP_BASE_URL=http://localhost:3030
# Local dev login (bypasses Auth0). Set to 1 for local dev; MUST be 0 in prod.
HDSEARCH_DEV_LOGIN=1

# ---- AI Search auth ----
# Set to false to allow AI Search without sign-in (uses public-demo identity).
# MUST be true in production / shared environments.
SIGN_IN_REQUIRED_FOR_AI=true

# ---- Auth0 (same tenant as hackerdogs-core / worldmonitor) ----
# If CLIENT_ID/SECRET are empty, a local dev login is used so the app still runs.
# hd-search needs its OWN "Regular Web Application" in this tenant (callback
# {APP_BASE_URL}/api/auth/callback) — do NOT reuse worldmonitor's SPA client.
# Same Auth0 config worldmonitor-main uses (working code): same tenant + SPA client id.
AUTH0_DOMAIN=dev-qvl70rmqadokdop1.us.auth0.com
AUTH0_CLIENT_ID=ACX4BvdDBpmT4AGAlCciqWpHCVkTVql4
AUTH0_CLIENT_SECRET=
# AUTH0_AUDIENCE=   # worldmonitor leaves this unset (uses the tenant default)

# ---- central auth + billing (hackerdogs-core) ----
# Core API base for token-exchange / GET /auth/me (dev: localhost:8000; deployed: preview).
HD_CORE_BASE_URL=http://localhost:8000
# On the core API host (root .env), include APP_BASE_URL in VERIFICATION_ALLOWED_ORIGINS so
# email activation links return here after verify. See docs/AUTH-CONFIG.md § Email verification.
# Central billing portal the "Upgrade" buttons link to (placeholder — wire the deep-link later).
NEXT_PUBLIC_CORE_BILLING_URL=
