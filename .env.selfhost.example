# HD-Search self-hosted stack — copy to `.env.selfhost` and fill in the secrets.
#
#   cp .env.selfhost.example .env.selfhost
#   docker compose --env-file .env.selfhost -f docker-compose.selfhost.yml up -d --build
#
# Generate the three secrets below (run each and paste the output):
#   HDSEARCH_ENCRYPTION_KEY   -> openssl rand -hex 32     (exactly 32 bytes / 64 hex chars)
#   HDSEARCH_INTERNAL_SECRET  -> openssl rand -hex 32
#   HDSEARCH_WEB_SESSION_SECRET -> openssl rand -hex 32

# ---- REQUIRED secrets (api & web share the internal secret; keep these stable) ----
# Losing HDSEARCH_ENCRYPTION_KEY makes any stored provider keys unreadable — back it up.
HDSEARCH_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32
HDSEARCH_INTERNAL_SECRET=CHANGE_ME_openssl_rand_hex_32
HDSEARCH_WEB_SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32

# ---- Datastore credentials (defaults are fine for a private/local deployment) ----
POSTGRES_USER=hdsearch
POSTGRES_PASSWORD=hdsearch
POSTGRES_DB=hdsearch
STORAGE_AWS_ACCESS_KEY_ID=hdsearch
STORAGE_AWS_SECRET_ACCESS_KEY=hdsearch-secret

# ---- Published host ports (change if these clash with something already running) ----
WEB_PORT=3000
API_PORT=8791
# Public URL the browser uses to reach the API (set to your host/IP if not localhost)
PUBLIC_API_URL=http://localhost:8791
APP_BASE_URL=http://localhost:3000

# ---- Optional ----
# HDSEARCH_OPENSERP_ENGINES=google,yandex,bing,baidu
# HDSEARCH_GEOCODER_URL=http://hds-photon:2322   # only with the `maps` profile
# WEAVIATE_ENABLE_CUDA=0                          # set 1 if you have an NVIDIA GPU
